# 本地开发：不配置 OAuth 时，点击「开发模式：进入仪表盘」会以此用户进入
DEV_USER_EMAIL=sherlin.chen.ny@gmail.com

# MySQL 连接串（开发直通需要数据库）
DATABASE_URL=mysql://user:password@localhost:3306/asset_tracker

# OpenCode / Claude（在项目目录运行 opencode 前需 source .env）
# ANTHROPIC_API_KEY=your-anthropic-api-key

# 可选：股票行情优先用 Finnhub（免费注册 https://finnhub.io/register，60 次/分钟，国内更稳定）
# FINNHUB_API_KEY=your-finnhub-api-key

# 可选：JWT 会话密钥（开发直通可不配）
# JWT_SECRET=your-secret

# 生产 / OAuth 登录时再配置
# VITE_APP_ID=
# VITE_OAUTH_PORTAL_URL=
# OAUTH_SERVER_URL=
