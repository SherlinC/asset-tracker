# 本地开发：不配置 OAuth 时，点击「开发模式：进入仪表盘」会以此用户进入
DEV_USER_EMAIL=sherlin.chen.ny@gmail.com

# MySQL 连接串（开发直通需要数据库）
DATABASE_URL=mysql://user:password@localhost:3306/asset_tracker

# OpenCode / Claude（在项目目录运行 opencode 前需 source .env）
# ANTHROPIC_API_KEY=your-anthropic-api-key

# 可选：LLM token（Forge 网关）。不配置时，AI 策略会退回实时规则引擎。
# BUILT_IN_FORGE_API_KEY=your-forge-api-key
# BUILT_IN_FORGE_API_URL=https://forge.manus.im

# 可选但建议：股票行情优先用 Finnhub（免费注册 https://finnhub.io/register，60 次/分钟，国内更稳定）
# AI 策略也会优先用它抓实时财经新闻。
# FINNHUB_API_KEY=your-finnhub-api-key

# 可选但强烈建议：国际基金 / ISIN 搜索与实时价格（免费注册 https://eodhd.com）
# EODHD_API_KEY=your-eodhd-api-key

# 价格缓存有效期（分钟），超过后实时抓取失败时不再回退旧缓存
PRICE_CACHE_MAX_AGE_MINUTES=10

# 可选：JWT 会话密钥（开发直通可不配）
# JWT_SECRET=your-secret

# 生产 / OAuth 登录时再配置
# VITE_APP_ID=
# VITE_OAUTH_PORTAL_URL=
# OAUTH_SERVER_URL=
